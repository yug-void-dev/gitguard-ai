# ============================================================
# GitGuard AI — Environment Variables (Week 2 Updated)
# ============================================================
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/gitguard

# ── GitHub Webhook ───────────────────────────────────────────
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_super_secret_webhook_secret_here

# ── GitHub OAuth ──────────────────────────────────────────────
# Create OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# ── JWT ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=your_32_character_jwt_secret_here_make_it_long
JWT_EXPIRES_IN=7d

# ── Rate Limiting ─────────────────────────────────────────────
WEBHOOK_RATE_LIMIT_MAX=30
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Security: IP Whitelist ────────────────────────────────────
# Optional: comma-separated IPs allowed to send webhooks.
# GitHub IP ranges: https://api.github.com/meta (hooks field)
# IP_WHITELIST=192.30.252.0,185.199.108.0

# ── Redis (BullMQ async review queue) ────────────────────────
# Docker Compose: REDIS_HOST=redis (service name), port=6379
# Local dev: localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank for no-auth Redis (dev only)
REDIS_PASSWORD=

# ── LLM API Keys (Week 2) ─────────────────────────────────────
# At least ONE of GEMINI_API_KEY or GROQ_API_KEY is required.
# Both = Gemini/Groq routing + fallback. One only = that provider only.

# Google Gemini 1.5 Flash — get key at https://aistudio.google.com/
# Best for: large diffs (1M context window), complex analysis
GEMINI_API_KEY=

# Groq Llama 3 70B — get key at https://console.groq.com/
# Best for: small/medium diffs, ultra-fast inference (300+ tok/s)
GROQ_API_KEY=

# Anthropic Claude (future support — not yet wired)
# ANTHROPIC_API_KEY=

# ── LLM Routing Config ────────────────────────────────────────
# Primary provider when both are available: gemini | groq
LLM_PRIMARY=gemini
# Max tokens per LLM response
LLM_MAX_TOKENS=8192
# Max diff bytes before chunking kicks in (default 100KB)
DIFF_MAX_CHUNK_BYTES=102400
