# ============================================================
# GitGuard AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/gitguard

# ── GitHub Webhook ───────────────────────────────────────────
# Set this as your GitHub webhook secret.
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_super_secret_webhook_secret_here

# ── GitHub OAuth (Week 3 — Dashboard Auth) ───────────────────
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# ── JWT ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=your_32_character_jwt_secret_here_make_it_long
JWT_EXPIRES_IN=7d

# ── Rate Limiting ────────────────────────────────────────────
WEBHOOK_RATE_LIMIT_MAX=30
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Security: IP Whitelist ────────────────────────────────────
# Optional: comma-separated IPs allowed to send webhooks.
# GitHub IP ranges: https://api.github.com/meta (hooks field)
# Leave empty to allow all IPs (HMAC signature is primary guard).
# IP_WHITELIST=192.30.252.0,185.199.108.0

# ── Redis (BullMQ queue — Week 2) ───────────────────────────
# Local dev: leave defaults (Docker Compose exposes Redis on localhost:6379)
# Docker: REDIS_HOST is automatically set to 'redis' (the service name)
# Production: use your managed Redis URL
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional — leave blank for no-auth Redis (development only!)
REDIS_PASSWORD=

# ── LLM API Keys ─────────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
LLM_PRIMARY=gemini

# ── SMTP / Email (Forgot Password OTP) ───────────────────────
# Leave all SMTP_* fields blank in development:
#   → The server will auto-create a free Ethereal.email test account
#     and print a clickable preview URL to the console.
# Fill in for staging / production with your real SMTP provider:
#   Gmail:  SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=app-password
#   SendGrid, Mailgun, AWS SES etc. follow the same pattern.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GitGuard AI <noreply@gitguard-ai.local>

