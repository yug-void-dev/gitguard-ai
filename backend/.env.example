# ============================================================
# GitGuard AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Server ───────────────────────────────────────────────────
# Port the Express server listens on
PORT=3001

# Application environment: development | staging | production
NODE_ENV=development

# ── GitHub Webhook ───────────────────────────────────────────
# Secret set in your GitHub repository webhook settings.
# Used for HMAC-SHA256 signature validation.
# Generate a strong random value: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_super_secret_webhook_secret_here

# ── MongoDB ──────────────────────────────────────────────────
# Full MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017/gitguard

# ── Rate Limiting ────────────────────────────────────────────
# Max requests per window per IP on webhook endpoint
WEBHOOK_RATE_LIMIT_MAX=30
# Window in milliseconds (default: 60000 = 1 minute)
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces)
# Example: https://gitguard.io,https://app.gitguard.io
ALLOWED_ORIGINS=http://localhost:3000

# ── Logging ──────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Security ─────────────────────────────────────────────────
# Optional: comma-separated list of IPs to whitelist for webhook
# Leave empty to allow all IPs (GitHub IPs only enforced by signature)
# IP_WHITELIST=

# ── Future: LLM Keys (Week 2+) ───────────────────────────────
# GEMINI_API_KEY=
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=
