# Backend Environment Variables

PORT=3001
NODE_ENV=development

# GitHub OAuth App and Webhook Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/callback
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_min_16_chars

# MongoDB Database Connection (e.g. MongoDB Atlas URI)
MONGODB_URI=mongodb://localhost:27017/gitguard

# JWT Session Security
JWT_SECRET=your_jwt_secret_must_be_at_least_32_chars_long
JWT_EXPIRES_IN=7d

# Cors Configuration (URL of the frontend e.g. Vercel deployment)
ALLOWED_ORIGINS=http://localhost:3000

# Redis configuration (Used for review queue and background worker)
# Set up these values from Upstash Redis console when deploying
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# LLM Providers API Keys (At least one is required)
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# LLM Preferences
LLM_PRIMARY=gemini
LLM_MAX_TOKENS=8192
DIFF_MAX_CHUNK_BYTES=102400

# SMTP Mail Server Configuration (For OTP password reset emails)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=GitGuard AI <noreply@gitguard-ai.local>
